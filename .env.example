# 大模型 API 配置（OpenAI 兼容接口）
# 复制本文件为 .env 后填写

# === DeepSeek（默认，推荐）===
LLM_PRESET=deepseek
LLM_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# === 通义千问（备选）===
# LLM_PRESET=qwen
# LLM_API_KEY=your_dashscope_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# === 豆包（备选）===
# LLM_PRESET=doubao
# LLM_API_KEY=your_ark_api_key_here
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=your_endpoint_id

# Gradio 配置
PORT=7860
# 设为 true 可生成临时公网链接（72小时有效，适合快速演示）
GRADIO_SHARE=false
